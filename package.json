    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jspdf": "^3.0.3",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
